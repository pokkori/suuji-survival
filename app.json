{
  "expo": {
    "name": "数字サバイバル",
    "slug": "number-survivor",
    "version": "1.0.0",
    "orientation": "portrait",
    "description": "数字サバイバル - スワイプして合計10にする数字パズル！落ちてくる数字を消してスコアを稼げ。3段階カスケードで爆発スコア！フィーバーモードで一気にクリア！キーワード: 数字パズル スワイプゲーム 数字ゲーム パズルゲーム 数学ゲーム",
    "keywords": ["数字サバイバル", "数字パズル", "スワイプゲーム", "NumberSurvivor", "数字ゲーム"],
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "number-survivor",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.numvivor.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.numvivor.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "title": "数字サバイバル - スワイプで10を作る数字パズル",
      "description": "落ちてくる数字をスワイプして合計10に！3段カスケードで爆発スコア。フィーバーモードで高得点を狙え。",
      "themeColor": "#1a1a3e"
    },
    "plugins": [
      "expo-router",
      "expo-sharing"
    ]
  }
}
